  "question_pt": "Como evoluiram as internacoes obstetricas por ano?",
  "executed_at": "2026-05-13T09:45:23",
  "database_file": "sihrd5.duckdb",
  "sql": "SELECT year(i.DT_INTER) AS ano, e.DESCRICAO AS especialidade, COUNT(*) AS internacoes FROM internacoes i JOIN especialidade e ON i.ESPEC = e.ESPEC WHERE e.DESCRICAO ILIKE '%OBSTETRICIA%' GROUP BY 1, 2 ORDER BY 1, 2",
