  "database_file": "sihrd5.duckdb",
  "sql": "WITH proc_uf AS (SELECT m.SG_UF, p.NOME_PROC, COUNT(*) AS ocorrencias, ROW_NUMBER() OVER (PARTITION BY m.SG_UF ORDER BY COUNT(*) DESC) AS rn FROM internacao_procedimento ip JOIN internacoes i ON ip.N_AIH = i.N_AIH JOIN municipios m ON i.MUNIC_RES = m.CO_MUNICIPIO_6D JOIN procedimentos p ON ip.PROC_REA = p.PROC_REA GROUP BY 1, 2) SELECT SG_UF, NOME_PROC, ocorrencias FROM proc_uf WHERE rn = 1 ORDER BY SG_UF",
