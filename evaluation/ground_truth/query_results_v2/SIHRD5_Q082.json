{
  "id": "SIHRD5_Q082",
  "question_pt": "Qual foi o mix percentual de carater de internacao por ano?",
  "executed_at": "2026-05-14T03:40:11.610368+00:00",
  "database_file": "sihrd5.duckdb",
  "sql": "WITH base AS (SELECT year(i.DT_INTER) AS ano, c.DESCRICAO AS carater, COUNT(*) AS internacoes FROM internacoes i JOIN car_int c ON i.CAR_INT = c.CAR_INT GROUP BY 1, 2), total AS (SELECT ano, SUM(internacoes) AS total_ano FROM base GROUP BY 1) SELECT b.ano, b.carater, b.internacoes, ROUND(100.0 * b.internacoes / t.total_ano, 4) AS percentual_ano FROM base b JOIN total t ON b.ano = t.ano ORDER BY b.ano, percentual_ano DESC, b.carater",
