  "question_pt": "Como as internacoes por sexo se distribuem em cada UF?",
  "executed_at": "2026-05-13T19:25:46",
  "database_file": "sihrd5.duckdb",
  "sql": "SELECT m.SG_UF, s.DESCRICAO AS sexo, COUNT(*) AS internacoes FROM internacoes i JOIN municipios m ON i.MUNIC_RES = m.CO_MUNICIPIO_6D JOIN sexo s ON i.SEXO = s.SEXO GROUP BY 1, 2 ORDER BY 1, internacoes DESC",
