  "question_pt": "Quantas internacoes ocorreram em UF de residencia diferente da UF do hospital? (considerando apenas internacoes com municipio de residencia mapeado)",
  "executed_at": "2026-05-14T03:40:14.441342+00:00",
  "database_file": "sihrd5.duckdb",
  "sql": "WITH fluxo AS (SELECT mr.SG_UF AS uf_residencia, mh.SG_UF AS uf_hospital, COUNT(*) AS internacoes FROM internacoes i JOIN municipios mr ON i.MUNIC_RES = mr.CO_MUNICIPIO_6D JOIN hospital h ON i.CNES = h.CNES JOIN municipios mh ON h.MUNIC_MOV = mh.CO_MUNICIPIO_6D GROUP BY 1, 2) SELECT uf_residencia, uf_hospital, internacoes FROM fluxo WHERE uf_residencia <> uf_hospital ORDER BY internacoes DESC LIMIT 30",
