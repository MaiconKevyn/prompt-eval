  "question_pt": "Qual e a media de permanencia por UF de residencia? (considerando apenas internacoes com municipio de residencia mapeado) segundo o campo DIAS_PERM",
  "executed_at": "2026-05-14T03:39:03.331213+00:00",
  "database_file": "sihrd5.duckdb",
  "sql": "SELECT m.SG_UF, ROUND((SUM(CAST(i.DIAS_PERM AS DECIMAL(20,2)))::DOUBLE / COUNT(i.DIAS_PERM)), 2) AS media_dias_permanencia, COUNT(*) AS internacoes FROM internacoes i JOIN municipios m ON i.MUNIC_RES = m.CO_MUNICIPIO_6D GROUP BY 1 ORDER BY media_dias_permanencia DESC, SG_UF",
