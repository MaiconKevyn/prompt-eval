  "question_pt": "Qual foi a variacao ano contra ano no volume de internacoes?",
  "executed_at": "2026-05-14T03:39:31.001939+00:00",
  "database_file": "sihrd5.duckdb",
  "sql": "WITH anual AS (SELECT year(DT_INTER) AS ano, COUNT(*) AS internacoes FROM internacoes GROUP BY 1) SELECT ano, internacoes, internacoes - LAG(internacoes) OVER (ORDER BY ano) AS diff_abs, ROUND(100.0 * (internacoes - LAG(internacoes) OVER (ORDER BY ano)) / NULLIF(LAG(internacoes) OVER (ORDER BY ano), 0), 4) AS diff_pct FROM anual ORDER BY ano",
