      "generated_sql": "WITH internacoes_com_municipio AS (\n    SELECT i.N_AIH, i.SEXO, i.MUNIC_RES\n    FROM internacoes i\n    JOIN municipios m ON i.MUNIC_RES = m.CO_MUNICIPIO_6D\n    WHERE m.SG_UF IS NOT NULL AND m.SG_UF != ''\n)\nSELECT \n    m.SG_UF AS UF,\n    s.DESCRICAO AS Sexo,\n    COUNT(i.N_AIH) AS total_internacoes\nFROM internacoes_com_municipio i\nJOIN municipios m ON i.MUNIC_RES = m.CO_MUNICIPIO_6D\nJOIN sexo s ON i.SEXO = s.SEXO\nGROUP BY m.SG_UF, s.DESCRICAO\nORDER BY m.SG_UF, s.DESCRICAO;",
