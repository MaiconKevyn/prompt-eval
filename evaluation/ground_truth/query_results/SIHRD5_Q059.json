  "question_pt": "Quais municipios dos hospitais tiveram mais internacoes?",
  "executed_at": "2026-05-13T09:45:23",
  "database_file": "sihrd5.duckdb",
  "sql": "SELECT mh.SG_UF, mh.NO_MUNICIPIO, COUNT(*) AS internacoes FROM internacoes i JOIN hospital h ON i.CNES = h.CNES JOIN municipios mh ON h.MUNIC_MOV = mh.CO_MUNICIPIO_6D GROUP BY 1, 2 ORDER BY internacoes DESC LIMIT 20",
